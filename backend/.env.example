# Backend Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git

# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# JWT secret (generate with: openssl rand -base64 32)
JWT_SECRET=change_me_to_a_secure_random_string

# Admin login password (change in production!)
ADMIN_PASSWORD=change_me_to_a_secure_password

# Frontend URL (used for CORS)
CORS_ORIGIN=http://localhost:3000

# Server port
PORT=3001

# Environment: development | production
NODE_ENV=development

# ────────────────────────────────────────────────────────────
# Cloudinary (image uploads) — REQUIRED for file uploads
# ────────────────────────────────────────────────────────────
# Sign up free at https://cloudinary.com/
# After signing up, go to Dashboard and copy these 3 values
# 1. Visit https://console.cloudinary.com/
# 2. Sign up / Log in
# 3. On the Dashboard, copy:
#    - Cloud Name
#    - API Key
#    - API Secret (click "Reveal" to see it)
CLOUDINARY_CLOUD_NAME=dkfrwgdcs
CLOUDINARY_API_KEY=341537811642525
CLOUDINARY_API_SECRET=wiYI9l1I_D6B5Hfu5zW6f2hhFgc
# Folder in Cloudinary where files are stored (default: 86connects)
CLOUDINARY_FOLDER=86connects


# ────────────────────────────────────────────────────────────
# Cloudflare R2 (PDF, DOC uploads) — OPTIONAL
# ────────────────────────────────────────────────────────────
# Required only if you want to accept non-image files
# (PDFs, DOCs, XLSs, TXTs)
# 1. Visit https://dash.cloudflare.com/
# 2. Go to R2 → Create bucket
# 3. Generate an API token with Object Read & Write
# 4. Allow public access to the bucket (or use a custom domain)
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here
R2_BUCKET_NAME=your_bucket_name_here
# Optional: custom public URL (e.g., https://files.86connects.com)
R2_PUBLIC_URL=https://pub-your_hash.r2.dev

# ────────────────────────────────────────────────────────────
# Email notifications via Resend — OPTIONAL
# ────────────────────────────────────────────────────────────
# 1. Sign up at https://resend.com/
# 2. Create an API key at https://resend.com/api-keys
# 3. Verify your sending domain
RESEND_API_KEY=re_xxxxxxxxxx
# Email that receives admin notifications
NOTIFY_EMAIL=beijingbridgepath@gmail.com
# Email that sends notifications (must be verified in Resend)
FROM_EMAIL=beijingbridgepath@gmail.com
