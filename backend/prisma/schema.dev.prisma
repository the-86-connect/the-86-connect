// Local Development Schema (SQLite)
generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  phone         String?
  passwordHash  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  submissions   Submission[]
  consultations Consultation[]
  notifications Notification[]

  @@index([deletedAt])
}

model Submission {
  id              String           @id @default(uuid())
  userId          String?
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  name            String
  email           String
  phone           String?
  serviceInterest String
  submissionType  String           @default("contact")
  message         String
  status          String           @default("submitted")
  statusHistory   Json?            @map("status_history")
  read            Boolean          @default(false)
  referenceCode   String?          @unique
  createdAt       DateTime         @default(now())
  deletedAt       DateTime?
  attachments     Attachment[]
  notes           SubmissionNote[]

  @@index([deletedAt])
}

model SubmissionNote {
  id           String     @id @default(uuid())
  submissionId String     @map("submission_id")
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  content      String
  authorName   String     @default("Admin") @map("author_name")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([submissionId])
  @@map("submission_notes")
}

model Attachment {
  id              String     @id @default(uuid())
  submissionId    String
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  originalName    String
  fileName        String
  url             String
  storageProvider String
  mimeType        String
  size            Int
  createdAt       DateTime   @default(now())

  @@index([submissionId])
}

model Video {
  id        String   @id @default(uuid())
  youtubeId String
  title     String
  page      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([page])
}

model Consultation {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name          String
  email         String
  phone         String?
  service       String   @default("general")
  meetingType   String   @default("online") // "online" | "phone"
  preferredDate DateTime
  preferredTime String   // e.g. "09:00"
  timezone      String   @default("UTC")
  message       String   @default("")
  status        String   @default("pending") // "pending" | "confirmed" | "completed" | "cancelled" | "rescheduled"
  adminNotes    String?
  meetingUrl    String?  // Set by admin when confirming online meetings
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  availabilitySlot AvailabilitySlot?

  @@index([status])
  @@index([preferredDate])
  @@index([userId])
  @@index([deletedAt])
  @@map("consultations")
}

model Notification {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String   // "submission_status" | "consultation_update"
  title         String
  message       String
  read          Boolean  @default(false)
  referenceId   String   // submission.id or consultation.id
  referenceCode String?  // for tracking link
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model AvailabilitySlot {
  id              String        @id @default(uuid())
  date            DateTime
  startTime       String
  endTime         String
  status          String        @default("available") // "available" | "booked" | "blocked"
  consultationId  String?       @unique
  consultation    Consultation? @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([date, startTime])
  @@index([date])
  @@index([status])
}

model LoginAttempt {
  id          String   @id @default(uuid())
  email       String
  ip          String
  type        String   @default("user") // "admin" | "user"
  attempts    Int      @default(1)
  lockedUntil DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([email, type])
  @@index([ip])
  @@index([lockedUntil])
  @@map("login_attempts")
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  passwordHash String
  role         String    @default("admin") // "admin" | "superadmin"
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admin_users")
}

model BlogPost {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  excerpt   String
  category  String   // "Study in China" | "Product Sourcing" | "Guide"
  date      String   // Formatted date string e.g. "June 20, 2026"
  readTime  String   @map("read_time") // e.g. "12 min read"
  author    String
  tags      Json     // string[]
  content   Json     // BlogSection[]
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([published])
  @@index([order])
  @@map("blog_posts")
}
