// Local Development Schema (SQLite)
generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  phone         String?
  passwordHash  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  submissions   Submission[]
  consultations Consultation[]
}

model Submission {
  id              String           @id @default(uuid())
  userId          String?
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  name            String
  email           String
  phone           String?
  serviceInterest String
  submissionType  String           @default("contact")
  message         String
  status          String           @default("submitted")
  statusHistory   Json?            @map("status_history")
  read            Boolean          @default(false)
  referenceCode   String?          @unique
  createdAt       DateTime         @default(now())
  attachments     Attachment[]
  notes           SubmissionNote[]
}

model SubmissionNote {
  id           String     @id @default(uuid())
  submissionId String     @map("submission_id")
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  content      String
  authorName   String     @default("Admin") @map("author_name")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([submissionId])
  @@map("submission_notes")
}

model Attachment {
  id              String     @id @default(uuid())
  submissionId    String
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  originalName    String
  fileName        String
  url             String
  storageProvider String
  mimeType        String
  size            Int
  createdAt       DateTime   @default(now())

  @@index([submissionId])
}

model Video {
  id        String   @id @default(uuid())
  youtubeId String
  title     String
  page      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([page])
}

model Consultation {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name          String
  email         String
  phone         String?
  service       String   @default("general")
  meetingType   String   @default("online") // "online" | "phone"
  preferredDate DateTime
  preferredTime String   // e.g. "09:00"
  timezone      String   @default("UTC")
  message       String   @default("")
  status        String   @default("pending") // "pending" | "confirmed" | "completed" | "cancelled" | "rescheduled"
  adminNotes    String?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([preferredDate])
  @@index([userId])
  @@map("consultations")
}
