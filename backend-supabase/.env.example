# Supabase Backend Environment Variables
# Copy to .env and fill in real values from your Supabase project dashboard.
# NEVER commit .env to git

# ────────────────────────────────────────────────────────────
# Supabase Project
# ────────────────────────────────────────────────────────────
# 1. Go to https://app.supabase.com
# 2. Create a new project
# 3. Go to Project Settings → API
# 4. Copy your Project URL, anon key, and service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ────────────────────────────────────────────────────────────
# Database (Supabase PostgreSQL)
# ────────────────────────────────────────────────────────────
# Go to Project Settings → Database → Connection string
# Use the "Session pooler" connection string for Prisma.
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Direct (non-pooling) connection for migrations
# Format: postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres.xxxxxxxxxxxxx:[YOUR-PASSWORD]@db.xxxxxxxxxxxxx.supabase.co:5432/postgres

# ────────────────────────────────────────────────────────────
# JWT Secret (for user token verification)
# ────────────────────────────────────────────────────────────
# Go to Project Settings → API → JWT Settings
# Copy the "JWT Secret" value
JWT_SECRET=your_supabase_jwt_secret

# ────────────────────────────────────────────────────────────
# Admin Setup
# ────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change_me_to_a_secure_password

# ────────────────────────────────────────────────────────────
# Frontend URL (CORS)
# ────────────────────────────────────────────────────────────
# For production, include your Vercel domain(s):
#   CORS_ORIGIN=https://the86connects.vercel.app,https://yourdomain.com
CORS_ORIGIN=http://localhost:3000

# Server port
PORT=3001

# Environment: development | production
NODE_ENV=development

# ────────────────────────────────────────────────────────────
# Email notifications via Resend — OPTIONAL
# ────────────────────────────────────────────────────────────
# 1. Sign up at https://resend.com/
# 2. Create an API key at https://resend.com/api-keys
# 3. Verify your sending domain
RESEND_API_KEY=re_xxxxxxxxxx
NOTIFY_EMAIL=beijingbridgepath@gmail.com
FROM_EMAIL=beijingbridgepath@gmail.com